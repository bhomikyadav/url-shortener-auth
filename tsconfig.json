{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "types": ["node"],

    "strict": true,

    "sourceMap": true,

    "declaration": false,

    "isolatedModules": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
